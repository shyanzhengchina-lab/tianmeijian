/**
 * 设备档案模块Zustand Store
 * 管理设备的本地状态和API调用
 * 保持与现有数据结构完全一致
 */
import { create } from 'zustand';
import { equipmentApi } from './api';
import { DEFAULT_EQUIPMENT } from './types';
import type {
  EquipRecord,
  EquipmentQuery,
  CreateEquipmentDTO,
  UpdateEquipmentDTO,
  EquipmentBatchAction,
} from './types';
import type { PaginationState } from '../../../shared/types/common';

interface EquipmentStore {
  // State
  equipments: EquipRecord[];
  selectedIds: string[];
  currentEquipment: EquipRecord | null;
  filters: EquipmentQuery;
  pagination: PaginationState;
  loading: boolean;
  error: string | null;
  statistics: {
    totalCount: number;
    activeCount: number;
    idleCount: number;
    maintenanceCount: number;
    faultCount: number;
    scrappedCount: number;
    disabledCount: number;
    categoryStats: Record<string, number>;
    avgOee: number;
    overdueMaintCount: number;
  } | null;

  // Actions
  loadEquipments: (query?: EquipmentQuery) => Promise<void>;
  loadAllEquipments: () => Promise<void>;
  loadStatistics: () => Promise<void>;
  createEquipment: (data: CreateEquipmentDTO) => Promise<void>;
  updateEquipment: (data: UpdateEquipmentDTO) => Promise<void>;
  deleteEquipments: (ids: string[]) => Promise<void>;
  batchEquipments: (action: EquipmentBatchAction) => Promise<void>;
  activateEquipment: (id: string) => Promise<void>;
  deactivateEquipment: (id: string) => Promise<void>;
  scrapEquipment: (id: string) => Promise<void>;
  setMaintenance: (id: string) => Promise<void>;
  unsetMaintenance: (id: string) => Promise<void>;
  updateStatus: (ids: string[], status: 'ACTIVE' | 'IDLE' | 'MAINTENANCE' | 'FAULT' | 'SCRAPPED' | 'DISABLED') => Promise<void>;

  // State setters
  setFilters: (filters: Partial<EquipmentQuery>) => void;
  setSelectedIds: (ids: string[]) => void;
  setCurrentEquipment: (equipment: EquipRecord | null) => void;
  setPagination: (pagination: Partial<PaginationState>) => void;
  setLoading: (loading: boolean) => void;
  setError: (error: string | null) => void;
  reset: () => void;
}

// 创建Zustand Store
export const useEquipmentStore = create<EquipmentStore>()(
  (set, get) => ({
    // 初始状态
    equipments: DEFAULT_EQUIPMENT,
    selectedIds: [],
    currentEquipment: null,
    filters: {},
    pagination: {
      current: 1,
      pageSize: 15,
      total: DEFAULT_EQUIPMENT.length,
    },
    loading: false,
    error: null,
    statistics: null,

    // Actions
    loadEquipments: async (query?: EquipmentQuery) => {
      set({ loading: true, error: null });

      try {
        const { filters: currentFilters, pagination: currentPagination } = get();
        const finalQuery: EquipmentQuery = {
          ...currentFilters,
          ...query,
          current: query?.current || currentPagination.current,
          pageSize: query?.pageSize || currentPagination.pageSize,
        };

        const result = await equipmentApi.getEquipments(finalQuery);

        set({
          equipments: result.list,
          pagination: {
            current: result.current,
            pageSize: result.pageSize,
            total: result.total,
          },
          loading: false,
        });
      } catch (error: any) {
        set({
          error: error?.message || '加载设备列表失败',
          loading: false,
        });
        throw error;
      }
    },

    loadAllEquipments: async () => {
      try {
        const equipments = await equipmentApi.getAllEquipments();
        set({ equipments });
      } catch (error: any) {
        console.error('加载所有设备失败:', error);
        set({ error: error?.message || '加载设备列表失败' });
      }
    },

    loadStatistics: async () => {
      try {
        const statistics = await equipmentApi.getStatistics();
        set({ statistics });
      } catch (error: any) {
        console.error('加载设备统计失败:', error);
      }
    },

    createEquipment: async (data: CreateEquipmentDTO) => {
      set({ loading: true, error: null });

      try {
        const newEquipment = await equipmentApi.createEquipment(data);

        set({
          equipments: [newEquipment, ...get().equipments],
          pagination: { ...get().pagination, total: get().pagination.total + 1 },
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '创建设备失败',
          loading: false,
        });
        throw error;
      }
    },

    updateEquipment: async (data: UpdateEquipmentDTO) => {
      set({ loading: true, error: null });

      try {
        const updatedEquipment = await equipmentApi.updateEquipment(data);

        set({
          equipments: get().equipments.map(eq => eq.id === data.id ? updatedEquipment : eq),
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '更新设备失败',
          loading: false,
        });
        throw error;
      }
    },

    deleteEquipments: async (ids: string[]) => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.deleteEquipments(ids);

        set({
          equipments: get().equipments.filter(eq => !ids.includes(eq.id)),
          pagination: { ...get().pagination, total: get().pagination.total - ids.length },
          selectedIds: [],
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '删除设备失败',
          loading: false,
        });
        throw error;
      }
    },

    batchEquipments: async (action: EquipmentBatchAction) => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.batchEquipments(action);

        // 重新加载列表
        await get().loadEquipments();
        // 重新加载统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '批量操作失败',
          loading: false,
        });
        throw error;
      }
    },

    activateEquipment: async (id: string) => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.activateEquipment(id);

        set({
          equipments: get().equipments.map(eq =>
            eq.id === id ? { ...eq, status: 'ACTIVE' } : eq
          ),
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '启用设备失败',
          loading: false,
        });
        throw error;
      }
    },

    deactivateEquipment: async (id: string) => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.deactivateEquipment(id);

        set({
          equipments: get().equipments.map(eq =>
            eq.id === id ? { ...eq, status: 'DISABLED' } : eq
          ),
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '停用设备失败',
          loading: false,
        });
        throw error;
      }
    },

    scrapEquipment: async (id: string) => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.scrapEquipment(id);

        set({
          equipments: get().equipments.map(eq =>
            eq.id === id ? { ...eq, status: 'SCRAPPED' } : eq
          ),
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '报废设备失败',
          loading: false,
        });
        throw error;
      }
    },

    setMaintenance: async (id: string) => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.setMaintenance(id);

        set({
          equipments: get().equipments.map(eq =>
            eq.id === id ? { ...eq, status: 'MAINTENANCE' } : eq
          ),
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '设置保养状态失败',
          loading: false,
        });
        throw error;
      }
    },

    unsetMaintenance: async (id: string) => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.unsetMaintenance(id);

        set({
          equipments: get().equipments.map(eq =>
            eq.id === id ? { ...eq, status: 'IDLE' } : eq
          ),
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '取消保养状态失败',
          loading: false,
        });
        throw error;
      }
    },

    updateStatus: async (ids: string[], status: 'ACTIVE' | 'IDLE' | 'MAINTENANCE' | 'FAULT' | 'SCRAPPED' | 'DISABLED') => {
      set({ loading: true, error: null });

      try {
        await equipmentApi.updateStatus(ids, status);

        set({
          equipments: get().equipments.map(equipment =>
            ids.includes(equipment.id) ? { ...equipment, status } : equipment
          ),
          loading: false
        });

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '更新状态失败',
          loading: false,
        });
        throw error;
      }
    },

    // State setters
    setFilters: (filters: Partial<EquipmentQuery>) => {
      set(state => ({
        filters: { ...get().filters, ...filters },
        pagination: { ...get().pagination, current: 1 }
      }));
    },

    setSelectedIds: (ids: string[]) => {
      set({ selectedIds: ids });
    },

    setCurrentEquipment: (equipment: EquipRecord | null) => {
      set({ currentEquipment: equipment });
    },

    setPagination: (pagination: Partial<PaginationState>) => {
      set(state => ({
        pagination: { ...get().pagination, ...pagination }
      }));
    },

    setLoading: (loading: boolean) => {
      set({ loading });
    },

    setError: (error: string | null) => {
      set({ error });
    },

    reset: () => {
      set({
        equipments: DEFAULT_EQUIPMENT,
        selectedIds: [],
        currentEquipment: null,
        filters: {},
        pagination: {
          current: 1,
          pageSize: 15,
          total: DEFAULT_EQUIPMENT.length,
        },
        loading: false,
        error: null,
        statistics: null,
      });
    },
  })
);
