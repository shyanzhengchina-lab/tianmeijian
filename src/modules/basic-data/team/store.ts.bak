/**
 * 班组档案模块Zustand Store
 * 管理班组的本地状态和API调用
 * 保持与现有数据结构完全一致
 */
import { create } from 'zustand';
import { teamApi } from './api';
import { DEFAULT_TEAMS } from './types';
import type {
  Team,
  TeamQuery,
  CreateTeamDTO,
  UpdateTeamDTO,
  TeamBatchAction,
} from './types';
import type { PaginationState } from '../../../shared/types/common';

interface TeamStore {
  // State
  teams: Team[];
  selectedIds: string[];
  currentTeam: Team | null;
  filters: TeamQuery;
  pagination: PaginationState;
  loading: boolean;
  error: string | null;
  statistics: {
    totalCount: number;
    activeCount: number;
    disabledCount: number;
    workCenterStats: Record<string, number>;
    workshopStats: Record<string, number>;
  } | null;

  // Actions
  loadTeams: (query?: TeamQuery) => Promise<void>;
  loadAllTeams: () => Promise<void>;
  loadStatistics: () => Promise<void>;
  createTeam: (data: CreateTeamDTO) => Promise<void>;
  updateTeam: (data: UpdateTeamDTO) => Promise<void>;
  deleteTeams: (ids: string[]) => Promise<void>;
  batchTeams: (action: TeamBatchAction) => Promise<void>;
  updateStatus: (ids: string[], status: 'ACTIVE' | 'DISABLED') => Promise<void>;
  updateLeader: (id: string, leader: string) => Promise<void>;

  // State setters
  setFilters: (filters: Partial<TeamQuery>) => void;
  setSelectedIds: (ids: string[]) => void;
  setCurrentTeam: (team: Team | null) => void;
  setPagination: (pagination: Partial<PaginationState>) => void;
  setLoading: (loading: boolean) => void;
  setError: (error: string | null) => void;
  reset: () => void;
}

// 创建Zustand Store
export const useTeamStore = create<TeamStore>()(
  (set, get) => ({
    // 初始状态
    teams: DEFAULT_TEAMS,
    selectedIds: [],
    currentTeam: null,
    filters: {},
    pagination: {
      current: 1,
      pageSize: 15,
      total: DEFAULT_TEAMS.length,
    },
    loading: false,
    error: null,
    statistics: null,

    // Actions
    loadTeams: async (query?: TeamQuery) => {
      set({ loading: true, error: null });

      try {
        const { filters: currentFilters, pagination: currentPagination } = get();
        const finalQuery: TeamQuery = {
          ...currentFilters,
          ...query,
          current: query?.current || currentPagination.current,
          pageSize: query?.pageSize || currentPagination.pageSize,
        };

        const result = await teamApi.getTeams(finalQuery);

        set({
          teams: result.list,
          pagination: {
            current: result.current,
            pageSize: result.pageSize,
            total: result.total,
          },
          loading: false,
        });
      } catch (error: any) {
        set({
          error: error?.message || '加载班组列表失败',
          loading: false,
        });
        throw error;
      }
    },

    loadAllTeams: async () => {
      try {
        const teams = await teamApi.getAllTeams();
        set({ teams });
      } catch (error: any) {
        console.error('加载所有班组失败:', error);
        set({ error: error?.message || '加载班组列表失败' });
      }
    },

    loadStatistics: async () => {
      try {
        const statistics = await teamApi.getStatistics();
        set({ statistics });
      } catch (error: any) {
        console.error('加载班组统计失败:', error);
      }
    },

    createTeam: async (data: CreateTeamDTO) => {
      set({ loading: true, error: null });

      try {
        const newTeam = await teamApi.createTeam(data);

        set(state => ({
          teams: [newTeam, ...get().teams],
          pagination: { ...get().pagination, total: get().pagination.total + 1 },
          loading: false
        }));

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '创建班组失败',
          loading: false,
        });
        throw error;
      }
    },

    updateTeam: async (data: UpdateTeamDTO) => {
      set({ loading: true, error: null });

      try {
        const updatedTeam = await teamApi.updateTeam(data);

        set(state => ({
          teams: get().teams.map(t => t.id === data.id ? updatedTeam : t),
          loading: false
        }));
      } catch (error: any) {
        set({
          error: error?.message || '更新班组失败',
          loading: false,
        });
        throw error;
      }
    },

    deleteTeams: async (ids: string[]) => {
      set({ loading: true, error: null });

      try {
        await teamApi.deleteTeams(ids);

        set(state => ({
          teams: get().teams.filter(t => !ids.includes(t.id)),
          pagination: { ...get().pagination, total: get().pagination.total - ids.length },
          selectedIds: [],
          loading: false
        }));

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '删除班组失败',
          loading: false,
        });
        throw error;
      }
    },

    batchTeams: async (action: TeamBatchAction) => {
      set({ loading: true, error: null });

      try {
        await teamApi.batchTeams(action);

        // 重新加载列表
        await get().loadTeams();
        // 重新加载统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '批量操作失败',
          loading: false,
        });
        throw error;
      }
    },

    updateStatus: async (ids: string[], status: 'ACTIVE' | 'DISABLED') => {
      set({ loading: true, error: null });

      try {
        await teamApi.updateStatus(ids, status);

        set(state => ({
          teams: get().teams.map(team =>
            ids.includes(team.id) ? { ...team, status } : team
          ),
          loading: false
        }));

        // 更新统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '更新状态失败',
          loading: false,
        });
        throw error;
      }
    },

    updateLeader: async (id: string, leader: string) => {
      set({ loading: true, error: null });

      try {
        await teamApi.updateLeader(id, leader);

        set(state => ({
          teams: get().teams.map(t =>
            t.id === id ? { ...t, leader } : t
          ),
          loading: false
        }));
      } catch (error: any) {
        set({
          error: error?.message || '更新负责人失败',
          loading: false,
        });
        throw error;
      }
    },

    // State setters
    setFilters: (filters: Partial<TeamQuery>) => {
      set(state => ({
        filters: { ...get().filters, ...filters },
        pagination: { ...get().pagination, current: 1 }
      }));
    },

    setSelectedIds: (ids: string[]) => {
      set({ selectedIds: ids });
    },

    setCurrentTeam: (team: Team | null) => {
      set({ currentTeam: team });
    },

    setPagination: (pagination: Partial<PaginationState>) => {
      set(state => ({
        pagination: { ...get().pagination, ...pagination }
      }));
    },

    setLoading: (loading: boolean) => {
      set({ loading });
    },

    setError: (error: string | null) => {
      set({ error });
    },

    reset: () => {
      set({
        teams: DEFAULT_TEAMS,
        selectedIds: [],
        currentTeam: null,
        filters: {},
        pagination: {
          current: 1,
          pageSize: 15,
          total: DEFAULT_TEAMS.length,
        },
        loading: false,
        error: null,
        statistics: null,
      });
    },
  })
);
