/**
 * 工作中心模块Zustand Store
 * 管理工作中心的本地状态和API调用
 * 保持与现有数据结构完全一致
 */
import { create } from 'zustand';

import { workCenterApi } from './api';
import { DEFAULT_WORK_CENTERS } from './types';
import type {
  WorkCenter,
  WorkCenterQuery,
  CreateWorkCenterDTO,
  UpdateWorkCenterDTO,
  WorkCenterBatchAction,
} from './types';
import type { PaginationState } from '../../../shared/types/common';

interface WorkCenterStore {
  // State
  workCenters: WorkCenter[];
  selectedIds: string[];
  currentWorkCenter: WorkCenter | null;
  filters: WorkCenterQuery;
  pagination: PaginationState;
  loading: boolean;
  error: string | null;
  statistics: {
    totalCount: number;
    activeCount: number;
    disabledCount: number;
    maintenanceCount: number;
    categoryStats: Record<string, number>;
  } | null;

  // Actions
  loadWorkCenters: (query?: WorkCenterQuery) => Promise<void>;
  loadAllWorkCenters: () => Promise<void>;
  loadStatistics: () => Promise<void>;
  createWorkCenter: (data: CreateWorkCenterDTO) => Promise<void>;
  updateWorkCenter: (data: UpdateWorkCenterDTO) => Promise<void>;
  deleteWorkCenters: (ids: string[]) => Promise<void>;
  batchWorkCenters: (action: WorkCenterBatchAction) => Promise<void>;
  updateStatus: (ids: string[], status: 'ACTIVE' | 'DISABLED') => Promise<void>;
  setMaintenance: (id: string) => Promise<void>;
  unsetMaintenance: (id: string) => Promise<void>;
  updateLeader: (id: string, leader: string) => Promise<void>;

  // State setters
  setFilters: (filters: Partial<WorkCenterQuery>) => void;
  setSelectedIds: (ids: string[]) => void;
  setCurrentWorkCenter: (workCenter: WorkCenter | null) => void;
  setPagination: (pagination: Partial<PaginationState>) => void;
  setLoading: (loading: boolean) => void;
  setError: (error: string | null) => void;
  reset: () => void;
}

// 创建Zustand Store
export const useWorkCenterStore = create<WorkCenterStore>()(
  (set, get) => ({
    // 初始状态
    workCenters: DEFAULT_WORK_CENTERS,
    selectedIds: [],
    currentWorkCenter: null,
    filters: {},
    pagination: {
      current: 1,
      pageSize: 15,
      total: DEFAULT_WORK_CENTERS.length,
    },
    loading: false,
    error: null,
    statistics: null,

    // Actions
    loadWorkCenters: async (query?: WorkCenterQuery) => {
      set({ loading: true, error: null });

      try {
        const { filters: currentFilters, pagination: currentPagination } = get();
        const finalQuery: WorkCenterQuery = {
          ...currentFilters,
          ...query,
          current: query?.current || currentPagination.current,
          pageSize: query?.pageSize || currentPagination.pageSize,
        };

        const result = await workCenterApi.getWorkCenters(finalQuery);

        set({
          workCenters: result.list,
          pagination: {
            current: result.current,
            pageSize: result.pageSize,
            total: result.total,
          },
          loading: false,
        });
      } catch (error: any) {
        set({
          error: error?.message || '加载工作中心列表失败',
          loading: false,
        });
        throw error;
      }
    },

    loadAllWorkCenters: async () => {
      try {
        const workCenters = await workCenterApi.getAllWorkCenters();
        set({ workCenters });
      } catch (error: any) {
        console.error('加载所有工作中心失败:', error);
        set({ error: error?.message || '加载工作中心列表失败' });
      }
    },

    loadStatistics: async () => {
      try {
        const statistics = await workCenterApi.getStatistics();
        set({ statistics });
      } catch (error: any) {
        console.error('加载工作中心统计失败:', error);
      }
    },

    createWorkCenter: async (data: CreateWorkCenterDTO) => {
      set({ loading: true, error: null });

      try {
        const newWorkCenter = await workCenterApi.createWorkCenter(data);

        set({
          workCenters: [newWorkCenter, ...get().workCenters],
          pagination: { ...get().pagination, total: get().pagination.total + 1 },
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '创建工作中心失败',
          loading: false,
        });
        throw error;
      }
    },

    updateWorkCenter: async (data: UpdateWorkCenterDTO) => {
      set({ loading: true, error: null });

      try {
        const updatedWorkCenter = await workCenterApi.updateWorkCenter(data);

        set({
          workCenters: get().workCenters.map(wc => wc.id === data.id ? updatedWorkCenter : wc),
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '更新工作中心失败',
          loading: false,
        });
        throw error;
      }
    },

    deleteWorkCenters: async (ids: string[]) => {
      set({ loading: true, error: null });

      try {
        await workCenterApi.deleteWorkCenters(ids);

        set({
          workCenters: get().workCenters.filter(wc => !ids.includes(wc.id)),
          pagination: { ...get().pagination, total: get().pagination.total - ids.length },
          selectedIds: [],
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '删除工作中心失败',
          loading: false,
        });
        throw error;
      }
    },

    batchWorkCenters: async (action: WorkCenterBatchAction) => {
      set({ loading: true, error: null });

      try {
        await workCenterApi.batchWorkCenters(action);

        // 重新加载列表
        await get().loadWorkCenters();
        // 重新加载统计
        await get().loadStatistics();
      } catch (error: any) {
        set({
          error: error?.message || '批量操作失败',
          loading: false,
        });
        throw error;
      }
    },

    updateStatus: async (ids: string[], status: 'ACTIVE' | 'DISABLED') => {
      set({ loading: true, error: null });

      try {
        await workCenterApi.updateStatus(ids, status);

        set({
          workCenters: get().workCenters.map(wc =>
            ids.includes(wc.id) ? { ...wc, status } : wc
          ),
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '更新状态失败',
          loading: false,
        });
        throw error;
      }
    },

    setMaintenance: async (id: string) => {
      set({ loading: true, error: null });

      try {
        await workCenterApi.setMaintenance(id);

        set({
          workCenters: get().workCenters.map(w =>
            w.id === id ? { ...w, status: 'MAINTENANCE' } : w
          ),
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '设置整修状态失败',
          loading: false,
        });
        throw error;
      }
    },

    unsetMaintenance: async (id: string) => {
      set({ loading: true, error: null });

      try {
        await workCenterApi.unsetMaintenance(id);

        set({
          workCenters: get().workCenters.map(w =>
            w.id === id ? { ...w, status: 'ACTIVE' } : w
          ),
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '取消整修状态失败',
          loading: false,
        });
        throw error;
      }
    },

    updateLeader: async (id: string, leader: string) => {
      set({ loading: true, error: null });

      try {
        await workCenterApi.updateLeader(id, leader);

        set({
          workCenters: get().workCenters.map(w =>
            w.id === id ? { ...w, leader } : w
          ),
          loading: false
        });
      } catch (error: any) {
        set({
          error: error?.message || '更新负责人失败',
          loading: false,
        });
        throw error;
      }
    },

    // State setters
    setFilters: (filters: Partial<WorkCenterQuery>) => {
      set(state => ({
        filters: { ...get().filters, ...filters },
        pagination: { ...get().pagination, current: 1 }
      }));
    },

    setSelectedIds: (ids: string[]) => {
      set({ selectedIds: ids });
    },

    setCurrentWorkCenter: (workCenter: WorkCenter | null) => {
      set({ currentWorkCenter: workCenter });
    },

    setPagination: (pagination: Partial<PaginationState>) => {
      set(state => ({
        pagination: { ...get().pagination, ...pagination }
      }));
    },

    setLoading: (loading: boolean) => {
      set({ loading });
    },

    setError: (error: string | null) => {
      set({ error });
    },

    reset: () => {
      set({
        workCenters: DEFAULT_WORK_CENTERS,
        selectedIds: [],
        currentWorkCenter: null,
        filters: {},
        pagination: {
          current: 1,
          pageSize: 15,
          total: DEFAULT_WORK_CENTERS.length,
        },
        loading: false,
        error: null,
        statistics: null,
      });
    },
  })
);
